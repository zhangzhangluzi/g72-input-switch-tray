{
  "name": "g72-input-switch-tray",
  "version": "0.1.6",
  "description": "用于在 DP2（Windows）和 HDMI1（Mac mini）之间切换 G72 输入源的跨平台托盘应用。",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --publish never",
    "dist:win": "electron-builder --win nsis --publish never",
    "dist:mac": "electron-builder --mac dmg zip --publish never",
    "release": "electron-builder --publish always"
  },
  "keywords": [
    "electron",
    "tray",
    "monitor",
    "ddc-ci"
  ],
  "author": "zhangzhangluzi",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.zhangzhangluzi.g72inputswitchtray",
    "productName": "G72 输入切换",
    "asar": true,
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "zhangzhangluzi",
        "repo": "g72-input-switch-tray",
        "releaseType": "release"
      }
    ],
    "mac": {
      "artifactName": "g72-input-switch-tray-${version}-${arch}.${ext}",
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ],
      "darkModeSupport": true,
      "extendInfo": {
        "LSUIElement": "1"
      }
    },
    "win": {
      "artifactName": "g72-input-switch-tray-setup-${version}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "G72 输入切换"
    }
  }
}
